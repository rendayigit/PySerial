{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Python: Install requirements",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "${workspaceFolder}/requirements.txt"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Python: Interactive py_serial",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-i", "${workspaceFolder}/py_serial.py"],
