{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Python: Install requirements",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "${workspaceFolder}/requirements.txt"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Python: Interactive py_serial",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-i", "${workspaceFolder}/py_serial.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Python: Interactive defined_messages",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-i", "${workspaceFolder}/defined_messages.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Python: Send idle",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-c", "import defined_messages; defined_messages.send_idle()"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Python: Start",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-c", "import defined_messages; defined_messages.start()"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Python: Stop",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-c", "import defined_messages; defined_messages.stop()"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Python: Run sample scenario",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["${workspaceFolder}/sample_scenario.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      },
      "problemMatcher": []
    }
  ]
}
